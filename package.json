{
  "name": "aion-sync",
  "version": "1.0.0",
  "description": "Sync time entries from Tempo (Jira) to Dyce — eternal, automatic, effortless.",
  "type": "commonjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alameenazad/aion.git"
  },
  "homepage": "https://github.com/alameenazad/aion#readme",
  "bugs": {
    "url": "https://github.com/alameenazad/aion/issues"
  },
  "keywords": [
    "cli",
    "tempo",
    "jira",
    "dyce",
    "timekeeping",
    "worklog",
    "time-tracking",
    "sync"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aion": "./dist/index.js"
  },
  "scripts": {
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "build": "tsup",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dayjs": "^1.11.11",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
